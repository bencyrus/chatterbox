# Postgres connection (over compose network)
DATABASE_URL=postgres://backup_service_user:backup_service_user_password@postgres:5432/chatterbox?sslmode=disable

# GCS upload
GCS_BACKUP_BUCKET=gcs-bucket-name
GCS_BACKUP_PREFIX=backups/postgres
GCS_CHATTERBOX_BUCKET_SERVICE_ACCOUNT_EMAIL=sa@project.iam.gserviceaccount.com
GCS_CHATTERBOX_BUCKET_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Schedule (cron expression, UTC)
BACKUP_SCHEDULE=0 5,17 * * * # 5am and 5pm UTC (midnight and noon in EST)